/*MALE PASSENGERS*/
SELECT PNAME FROM PASSENGER
WHERE SEX='M';


/*NAME WITH S ENDS WITH A*/
SELECT PNAME FROM PASSENGER
WHERE PNAME LIKE 'S%A';


/*NAMES ENDS WITH HA*/
SELECT PNAME FROM PASSENGER
WHERE PNAME LIKE '%HA';


/*MALE P ABOVE 30*/
SELECT PNAME FROM PASSENGER
WHERE SEX='M' && AGE>30;


/*AGE IS 29,30,34*/
SELECT PNAME FROM PASSENGER
WHERE SEX='M' && AGE IN (29,30,34);


/*BUSNO HYDERABAD */
SELECT BUSNO FROM BUS
WHERE SOURCE='HYDERABAD' OR SOURCE='VIZAG';


/*FEMALE IN DESC*/
SELECT PNAME FROM PASSENGER
WHERE SEX='F'
ORDER BY PNAME DESC;


/*ALTER TABLE WITHOUT PNO*/
ALTER TABLE PASSENGER
DROP COLUMN PHNO;

SELECT * FROM PASSENGER;


/*NO OF MALES NND FEMALES*/
SELECT SEX,COUNT(*) AS COUNT
FROM PASSENGER
WHERE AGE>=30
GROUP BY SEX;


/*FEMALE PASS AGE IS >25 STAY IN HYD,VIZ*/


/*NAME HAS RI*/
SELECT PNAME FROM PASSENGER
WHERE PNAME LIKE '%RI%';


/* FEMALE AGE IS 25 ND 36*/
SELECT PNAME FROM PASSENGER
WHERE SEX='F' && AGE BETWEEN 25 AND 36;


/*AGE IS 25,27,36*/
SELECT PNAME FROM PASSENGER
WHERE SEX='F' && AGE IN (25,27,36);


/**BUSNO HYDERABAD */
SELECT BUSNO,DESTINATION FROM BUS
WHERE SOURCE='VIZAG';


/*NO OF MALES IN DSC*/
SELECT PNAME FROM PASSENGER
WHERE SEX='M'
ORDER BY PNAME DESC;


/*ALTER WITHOUT DEPTTIME AND ARRIVAL TIME*/
ALTER TABLE BUS
DROP COLUMN DEPTTIME;
ALTER TABLE BUS
DROP COLUMN ARRIVALTIME;

SELECT * FROM BUS;

/*YOUNGEST PASS*/
SELECT PNAME FROM PASSENGER
WHERE AGE<=25;


