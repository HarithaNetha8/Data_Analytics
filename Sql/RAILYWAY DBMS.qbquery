CREATE TABLE CANCELLATION (
TICKETNO INT(10),
REFUNDAMOUNT INT(5));
INSERT INTO CANCELLATION VALUES(445522,525),(767676,460),(55555,600);
SELECT * FROM CANCELLATION;



CREATE TABLE reservation(
    TICKETNO INT(10),
    PNO INT PRIMARY KEY,
    BUSNO INT(20),
    JDATE VARCHAR(20),
    SEATING VARCHAR(10),
    FARE INT(10),
    PASSNGERstatus VARCHAR(20),
    FOREIGN KEY(BUSNO) REFERENCES bus(BUSNO));

