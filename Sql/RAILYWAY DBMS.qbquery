create database railyway;
use railyway;


CREATE TABLE bus(
 BUSNO INT PRIMARY KEY,
 SOURCE VARCHAR(20),
 DESTINATION VARCHAR(20),
 DEPTTIME VARCHAR(10),
 ARRIVALTIME VARCHAR(10));


